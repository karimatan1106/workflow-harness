{
  "name": "harness-log-pane",
  "displayName": "Harness Log Pane",
  "description": "Auto-split terminal for workflow harness worker logs",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "workspaceContains:.agent"
  ],
  "main": "./out/extension.js",
  "contributes": {},
