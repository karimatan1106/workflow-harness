{
  "permissions": {
    "allow": [
      "Edit **/*",
      "Write **/*",
      "Read **/*",
      "Bash(*)",
      "Glob **/*",
      "Grep **/*"
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          "node hooks/session-boundary.js"
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/rtk-rewrite.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          "node hooks/block-dangerous-commands.js"
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          "node hooks/loop-detector.js"
        ]
      },
      {
        "matcher": "",
        "hooks": [
          "node hooks/context-watchdog.js"
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-tool-guard.sh"
          }
        ]
      }
    ]
  }
}
