  PL-01, "pre-tool-guard.sh の is_lifecycle_mcp() をワイルドカードパターンに変更(実施済み)", workflow-harness/hooks/pre-tool-guard.sh, none
  PL-02, "manager-read.ts に resolveProjectPath の import を追加", workflow-harness/mcp-server/src/state/manager-read.ts, none
  PL-03, "getDocsPath() で resolveProjectPath(join(DOCS_DIR taskName)) を返すように変更", workflow-harness/mcp-server/src/state/manager-read.ts, PL-02
  PL-04, "既存テスト実行で docsDir が絶対パスになった影響を確認", workflow-harness/mcp-server/src/**/*.test.ts, PL-03

