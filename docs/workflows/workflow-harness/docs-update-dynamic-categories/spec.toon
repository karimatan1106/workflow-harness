  F-001, "ProjectTraits interface定義(hasUI/hasAPI/hasDB/hasEvents/hasI18n/hasDesignSystem)", "spec.toon PL-1", "src/state/types-core.ts", "types-core interface存在確認", "pending"
  F-002, "TaskState.projectTraitsオプショナルフィールド追加", "spec.toon PL-2", "src/state/types.ts", "npm run build型チェック", "pending"
  F-003, "harness_set_scope inputSchemaにprojectTraitsプロパティ追加", "spec.toon PL-5", "src/tools/defs-a.ts", "MCP定義の目視確認", "pending"
  F-004, "handleHarnessSetScopeでprojectTraits永続化", "spec.toon PL-5", "src/tools/handlers/scope-nav.ts", "harness_set_scope呼び出し後のTaskState検証", "pending"
  F-005, "buildDocCategories純粋関数の実装", "spec.toon PL-3/PL-6/PL-7", "src/phases/definitions.ts", "フラグ組み合わせ別の出力検証", "pending"
  F-006, "buildSubagentPromptへのprojectTraits引数追加と{docCategories}展開", "spec.toon PL-2", "src/phases/definitions.ts", "テンプレート展開結果の検証", "pending"
  F-007, "docs_updateテンプレートの固定リストを{docCategories}プレースホルダーに置換", "spec.toon PL-4/PL-8", "src/phases/defs-stage6.ts", "フォールバック出力の一致確認", "pending"
  F-008, "scope_definitionテンプレートにプロジェクト性質判定ステップ追加", "spec.toon PL-9", "src/phases/defs-stage1.ts", "テンプレート内容の目視確認", "pending"

architecture:
  layers: "3層変更: 型定義層(types-core.ts/types.ts) → API受付層(defs-a.ts/scope-nav.ts) → テンプレート注入層(definitions.ts/defs-stage6.ts/defs-stage1.ts/query.ts)"
  dataFlow: "scope_definitionサブエージェント → harness_set_scope(projectTraits) → TaskState.projectTraits永続化 → harness_get_subphase_template → buildSubagentPrompt(projectTraits) → buildDocCategories(traits) → {docCategories}展開 → docs_updateサブエージェント"
  fallbackChain: "projectTraits未設定 → buildDocCategories(undefined) → 現行固定5項目リスト返却"

buildDocCategoriesSpec:
  signature: "buildDocCategories(traits?: Record<string, boolean>): string"
  location: "src/phases/definitions.ts(buildSubagentPrompt直前に配置)"
  traitToCategories: "hasUI→screens/wireframes/components/interactions/responsive/accessibility, hasAPI→api, hasDB→database, hasEvents→events/messages, hasI18n→i18n/seo/sitemap.md, hasDesignSystem→design-system/components"
  deduplication: "Set<string>で同一パス排除。hasUIとhasDesignSystemの両方trueでもdocs/spec/components/は1回のみ"
  fallbackOutput: "traitsがundefined時は現行固定5項目を返却: 1. docs/architecture/overview.md 2. docs/operations/ 3. CHANGELOG.md 4. README.md 5. docs/workflows/→永続パス反映"
  dynamicOutput: "traitsがdefined時はフォールバック5項目+フラグ別カテゴリを番号付きリストで出力"

scopeNavPersistenceSpec:
  pattern: "handleHarnessSetScope内でsm.updateScope呼び出し後、args.projectTraitsが存在する場合に追加処理"
  steps: "1. const traits = args.projectTraits as Record<string,boolean> | undefined  2. if (traits) { const t = sm.loadTask(taskId); if(t) { (t as any).projectTraits = traits; sm.addProof(taskId, proofEntry); } }"
  rationale: "updateScopeシグネチャ変更を回避。addProofはsignAndPersistを内部で呼ぶため永続化が保証される"
  backwardCompat: "projectTraitsパラメータ省略時は既存動作に影響なし"

queryHandlerSpec:
  change: "handleHarnessGetSubphaseTemplate(query.ts L50-52)でtaskからprojectTraitsを取得しbuildSubagentPromptに第7引数として渡す"
  before: "buildSubagentPrompt(phase, taskName, docsDir, workflowDir, userIntent, taskId)"
  after: "buildSubagentPrompt(phase, taskName, docsDir, workflowDir, userIntent, taskId, (task as any).projectTraits)"

