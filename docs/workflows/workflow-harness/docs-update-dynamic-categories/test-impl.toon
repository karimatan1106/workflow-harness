next:
  criticalDecisions: "TD-I1(dynamic import+as any)はimplementationフェーズでbuildDocCategoriesがnamed exportされた時点で通常importに切り替える。TD-I3(ProjectTraits存在確認)は実装後にexport方式に合わせてアサーション修正が必要"
  readFiles: "src/__tests__/handler-dynamic-categories-unit.test.ts, src/__tests__/handler-dynamic-categories-integration.test.ts, src/phases/definitions.ts(buildDocCategories実装先), src/state/types-core.ts(ProjectTraits定義先)"
