taskStateFields:
  identity: "taskId(UUID), taskName, version(=4)"
  phaseTracking: "phase, completedPhases[], skippedPhases[], subPhaseStatus{}"
  sizing: "size(small/medium/large), riskScore{total, factors}"
  intent: "userIntent, openQuestions[], notInScope[]"
  scope: "scopeFiles[], scopeDirs[], scopeGlob?, plannedFiles[]"
  traceability: "acceptanceCriteria[AC-N], rtmEntries[F-NNN], proofLog[ProofEntry]"
  invariants: "invariants[INV-N]"
  checkpoint: "taskId/phase/completedPhases/timestamp/sha256/userIntent/scopeFiles/acceptanceCriteria/rtmEntries"
  paths: "docsDir, workflowDir"
  extended: "approvals{}, feedbackLog[], baseline{}, testResults[], resetHistory[], testFiles[], knownBugs[]"
  sprint12: "retryCount{}, artifactTimestamps{}, requirementCount, artifactHashes{}, parallelPhaseBackupLog[]"
  security: "sessionToken(64 hex), stateIntegrity(HMAC-SHA256)"
  metadata: "createdAt, updatedAt, parentTaskId?, childTaskIds?"

zodValidation:
  source: "types-core.ts:183-194"
  taskIdFormat: "z.string().uuid()"
  taskNameMin: "z.string().min(1)"
  versionLiteral: "z.literal(4)"
  phaseNameEnum: "z.enum(PHASE_NAMES)"
  sizeEnum: "z.enum(['small','medium','large'])"
  userIntentMin: "z.string().min(20)"
  sessionTokenMin: "z.string().min(32)"
  passthrough: "未知フィールドを許容(拡張性確保)"

