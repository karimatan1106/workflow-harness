  medium: "riskScore 4-7 -> ~22 phases (8 skipped)"
  large: "riskScore 8+ -> 30 phases (0 skipped)"
  skipMapSource: "registry.ts:91-124"

riskClassifier:
  source: "src/phases/risk-classifier.ts:17-58"
  fileCountScoring: ">=10 files: +3, >=5: +2, >=2: +1"
  codeLineScoring: ">=1000 lines: +2, >=200: +1"
  booleanFactors: "hasConfig: +1, hasInfra: +2, hasSecurity: +2, hasDatabase: +1, hasTests: +1"
  maxPossibleScore: 12
  scopeAnalysis: "risk-classifier.ts:41-58 (pattern matching on file/dir paths)"

