  IA-1, "OPEN_QUESTIONS存在+空チェック", requirements, "dod-l4-requirements.ts:105-124 / approval.ts:35-52"
  IA-2, "AC-N最低3件+NOT_IN_SCOPE必須", requirements, "dod-l4-requirements.ts:25-67 / approval.ts:54-60"
  IA-3, "acDesignMappingキー+全AC対応", design_review, "dod-l4-ia.ts:12-37"
