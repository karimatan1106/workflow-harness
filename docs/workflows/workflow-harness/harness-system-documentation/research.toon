hmacSecurity:
  source: "src/utils/hmac.ts:1-85"
  algorithm: "HMAC-SHA256"
  keyGeneration: "randomBytes(32).toString('hex') = 64 hex chars"
  keyRotation: "current + previous keys, verifyStateWithRotation tries both"
  stateSign: "canonical JSON (sorted keys) -> HMAC-SHA256"
  sessionToken: "randomBytes(32).toString('hex') = 64 hex chars"
  taskId: "crypto.randomUUID()"

reflectorCuratorAce:
  reflector: "src/tools/reflector.ts:1-153"
  reflectorTypes: "src/tools/reflector-types.ts:1-70"
  curator: "src/tools/curator.ts:1-140"
  curatorHelpers: "src/tools/curator-helpers.ts:1-98"
  aceContext: "src/tools/ace-context.ts:1-103"
  pipeline: "失敗→stashFailure→成功→promoteStashedFailure→Reflector→Curator(task完了時)→ACE(quality>=0.6昇格)"
  maxLessons: 50
  maxAfterCuration: 40
  staleThreshold: "30日"
  fuzzyDedupThreshold: 0.7
  acePromoteThreshold: 0.6
  qualityScore: "helpfulCount / (helpfulCount + harmfulCount + 1)"
  v2toV3Migration: "reflector-types.ts:51-70"

retrySystem:
  source: "src/tools/retry.ts:1-153"
  errorClasses: "FileNotFound/SyntaxError/LogicError/Unknown (EAC-1)"
  modelEscalation: "retry>=2 && haiku -> sonnet, retry>=3 -> sonnet forced"
  maxRetries: "5 (lifecycle.ts:77-80, RLM-1)"
  vdb1Warning: "3回同エラー -> バリデータバグ疑い (lifecycle.ts:100-102)"
  improvementMapping: "15 error patterns -> actionable instructions (retry.ts:34-128)"

entryPoints:
  mcpServer: "src/index.ts:1-48 (StdioServerTransport, @modelcontextprotocol/sdk)"
  cli: "src/cli.ts:1-109 (add-invariant/update-invariant-status subcommands)"
  serverVersion: "0.1.0"

