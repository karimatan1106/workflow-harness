    subgraph mcp["2. mcp-server/ 変更"]
        B --> B1[server.ts]
        B --> B2[state/*.ts]
        B --> B3[tools/*.ts]
        B --> B4[phases/*.ts]
        B --> B5[utils/*.ts]
    end

    B1 & B2 & B3 & B4 & B5 --> C[workflow-phases/]

    subgraph phases["3. workflow-phases/ 変更"]
        C --> C1[README.md]
        C --> C2[planning.md]
