  src/__tests__/handler-templates-s6-docs.test.ts, test, "defs-stage6.ts/registry.ts/definitions.tsの設定検証ユニットテスト(16件)。実装フェーズで作成"
  src/__tests__/handler-templates-s6-docs-integration.test.ts, test, "buildSubagentPrompt経由のdocs_update最終プロンプト統合検証(2件)。実装フェーズで作成"

next:
  criticalDecisions: "TD-4のOUTPUT_FILE_TO_PHASE間接検証が最も実装上の注意を要する。buildSubagentPromptの呼出引数(phase, taskName, docsDir, workflowDir, userIntent)を正確に設定し、docs-update.toonをinputFilesに含むフェーズを特定するか、テスト用にPHASE_REGISTRYの一時的なinputFiles設定が必要になる可能性がある"
  readFiles: "src/__tests__/handler-test-setup.ts, src/__tests__/handler-templates-s1.test.ts, src/phases/defs-stage6.ts, src/phases/registry.ts, src/phases/definitions.ts"
  warnings: "OUTPUT_FILE_TO_PHASEはエクスポートされていないため直接テスト不可。buildToonFirstSection経由の間接検証では、docs-update.toonをinputFilesに含むフェーズが現時点で存在しない可能性がある。その場合はTC-AC3-01の検証方法をdefinitions.tsのソースコード文字列検索(grep相当)に変更する必要がある"
