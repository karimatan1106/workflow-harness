  src/phases/defs-stage6.ts, impl, "docs_updateテンプレート全面改修 + commit/push/ci_verification/deployテンプレート圧縮。現201行を推定198行に調整"
  src/phases/registry.ts, impl, "docs_update PhaseConfig更新。model/inputFiles/outputFile/requiredSections/minLines/bashCategories変更"
  src/phases/definitions.ts, impl, "OUTPUT_FILE_TO_PHASEにdocs-update.toonエントリ追加(1行)"

next:
  criticalDecisions: "IMPL-1のテンプレート圧縮量が十分かの確認が最優先。commit/push/ci_verification/deployの圧縮後行数を正確に計測し、docs_updateテンプレート拡充の余裕が13行以上あることを確認してからIMPL-2に着手する"
  readFiles: "src/phases/defs-stage6.ts, src/phases/registry.ts, src/phases/definitions.ts, .claude/skills/harness/workflow-docs.md"
  warnings: "テンプレート文字列内の各改行が1行としてカウントされる。テンプレートリテラル(バッククォート)内の改行もwc -lで1行扱い。圧縮量の見積もりは正確だが、実装時にwc -lで実測すること"
