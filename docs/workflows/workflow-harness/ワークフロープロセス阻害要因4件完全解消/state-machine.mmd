%% 仕様サマリー
%% 本ファイルはB-1タスクソート、B-2 git操作許可、B-3ベースライン記録の3つのステートマシン図を含む

%% -------- B-1: タスク選択のステートマシン図 --------
%% discoverTasks()がタスクを列挙し、ソートし、選択するまでの状態遷移

stateDiagram-v2
    state "B1: タスク発見フロー" as B1 {
        [*] --> 状態遷移図開始

        状態遷移図開始 --> ワークフローディレクトリ確認

        ワークフローディレクトリ確認 --> ディレクトリ存在判定

        ディレクトリ存在判定 --> 存在しない場合は空配列を返す: ディレクトリなし
        存在しない場合は空配列を返す --> [*]

        ディレクトリ存在判定 --> ファイルシステムからディレクトリリスト読み込み: ディレクトリあり

        ファイルシステムからディレクトリリスト読み込み --> 各ディレクトリが有効か検証

        各ディレクトリが有効か検証 --> 正規表現マッチング処理実行

        正規表現マッチング処理実行 --> taskIdとtaskNameを抽出成功

        taskIdとtaskNameを抽出成功 --> タスクオブジェクト生成

        タスクオブジェクト生成 --> 配列にタスクを蓄積

        配列にタスクを蓄積 --> 全ディレクトリの処理完了判定

        全ディレクトリの処理完了判定 --> タスクIDの降順でソート実行: 処理完了

        タスクIDの降順でソート実行 --> localeCompareで文字列比較

        localeCompareで文字列比較 --> 最新のタスクが配列先頭に配置

        最新のタスクが配列先頭に配置 --> ソート済み配列を返却

        ソート済み配列を返却 --> [*]
    } %% B1タスク発見フロー終了

%% -------- B-2: git操作許可判定のステートマシン図 --------
%% analyzeBashCommand()がcommit/pushフェーズでgitコマンドを評価する状態遷移

    state "B2: git操作許可判定フロー" as B2 {
        [*] --> Bashコマンド受け取り

        Bashコマンド受け取り --> 現在のフェーズを確認

        現在のフェーズを確認 --> commitフェーズか判定

        commitフェーズか判定 --> commitではない場合: フェーズ確認続行
        commitフェーズか判定 --> git操作型チェック実行: commitフェーズ

        フェーズ確認続行 --> pushフェーズか判定

        pushフェーズか判定 --> pushではない場合: 他フェーズ処理へ移行
        pushフェーズか判定 --> git操作型チェック実行: pushフェーズ

        他フェーズ処理へ移行 --> 既存のチェックロジック適用: 他フェーズ
        既存のチェックロジック適用 --> [*]

        git操作型チェック実行 --> commitフェーズの処理開始: commit時
        git操作型チェック実行 --> pushフェーズの処理開始: push時

        commitフェーズの処理開始 --> git_addコマンドか検査

        git_addコマンドか検査 --> gitaddを許可: git add検出
        git_addコマンドか検査 --> git_commitコマンドか検査: git add非検出

        gitaddを許可 --> ホワイトリスト許可結果を返す

        git_commitコマンドか検査 --> git_commit修飾子検査

        git_commit修飾子検査 --> --amendが含まれているか確認

        --amendが含まれているか確認 --> 修飾子が危険: --amend検出
        --amendが含まれているか確認 --> --no-verifyが含まれているか確認: --amend非検出

        修飾子が危険 --> ブロック理由メッセージを生成: --amend拒否
        ブロック理由メッセージを生成 --> ホワイトリスト拒否結果を返す

        --no-verifyが含まれているか確認 --> 修飾子が危険: --no-verify検出
        --no-verifyが含まれているか確認 --> git_commitを許可: 危険な修飾子なし

        git_commitを許可 --> ホワイトリスト許可結果を返す

        git_tagコマンドか検査 --> git_tagを許可: git tag検出
        git_tagコマンドか検査 --> 他のコマンドはブロック: git tag非検出

        git_tagを許可 --> ホワイトリスト許可結果を返す

        他のコマンドはブロック --> ホワイトリスト拒否結果を返す

        pushフェーズの処理開始 --> git_pushコマンドか検査

        git_pushコマンドか検査 --> git_push危険オプション検査: git push検出
        git_pushコマンドか検査 --> 他のコマンドはブロック: git push非検出

        git_push危険オプション検査 --> --forceが含まれているか確認

        --forceが含まれているか確認 --> 破壊的オプション検出: --force検出
        --forceが含まれているか確認 --> -fオプションが含まれているか確認: --force非検出

        破壊的オプション検出 --> ブロック理由メッセージを生成: --force拒否
        ブロック理由メッセージを生成 --> ホワイトリスト拒否結果を返す

        -fオプションが含まれているか確認 --> 破壊的オプション検出: -f検出
        -fオプションが含まれているか確認 --> git_pushを許可: 危険なオプションなし

        git_pushを許可 --> ホワイトリスト許可結果を返す

        ホワイトリスト許可結果を返す --> [*]
        ホワイトリスト拒否結果を返す --> [*]
    } %% B2 git操作許可判定フロー終了

%% -------- B-3: ベースライン記録のステートマシン図 --------
%% captureBaseline()がフェーズを検証し記録する状態遷移

    state "B3: ベースライン記録フロー" as B3 {
        [*] --> ベースライン記録関数呼び出し

        ベースライン記録関数呼び出し --> taskIdを取得

        taskIdを取得 --> taskIdが指定されているか確認

        taskIdが指定されているか確認 --> taskIdなし: 指定なし
        taskIdが指定されているか確認 --> タスク状態を検索: 指定あり

        taskIdなし --> taskIdエラーを返す
        taskIdエラーを返す --> [*]

        タスク状態を検索 --> タスクが見つかったか判定

        タスクが見つかったか判定 --> タスク未検出: タスクなし
        タスクが見つかったか判定 --> 現在のフェーズを抽出: タスクあり

        タスク未検出 --> タスク未検出エラーを返す
        タスク未検出エラーを返す --> [*]

        現在のフェーズを抽出 --> 許可フェーズの判定処理

        許可フェーズの判定処理 --> researchフェーズか確認

        researchフェーズか確認 --> researchフェーズ時の処理: researchフェーズ
        researchフェーズか確認 --> testingフェーズか確認: research非検出

        researchフェーズ時の処理 --> 推奨初期ベースラインとして記録
        推奨初期ベースラインとして記録 --> recordedPhaseをresearchに設定
        recordedPhaseをresearchに設定 --> ベースラインメタデータ生成

        testingフェーズか確認 --> testingフェーズ時の処理: testingフェーズ
        testingフェーズか確認 --> 許可されていないフェーズ: testing非検出

        testingフェーズ時の処理 --> 警告ログを出力
        警告ログを出力 --> 遅延ベースラインとして記録
        遅延ベースラインとして記録 --> 推奨メッセージをログに追加
        推奨メッセージをログに追加 --> recordedPhaseをtestingに設定
        recordedPhaseをtestingに設定 --> ベースラインメタデータ生成

        許可されていないフェーズ --> フェーズ拒否エラーを返す
        フェーズ拒否エラーを返す --> [*]

        ベースラインメタデータ生成 --> テスト数をメタデータに格納
        テスト数をメタデータに格納 --> 合格数をメタデータに格納
        合格数をメタデータに格納 --> 不合格テスト一覧をメタデータに格納
        不合格テスト一覧をメタデータに格納 --> 記録タイムスタンプを生成
        記録タイムスタンプを生成 --> ベースラインをタスク状態に関連付け

        ベースラインをタスク状態に関連付け --> タスク状態をディスクに永続化

        タスク状態をディスクに永続化 --> 成功レスポンスを生成
        成功レスポンスを生成 --> [*]
    } %% B3ベースライン記録フロー終了
