  AC-1, "TC-AC1-01/TC-AC1-02/TC-AC1-03/TC-AC1-04/TC-AC1-05", "正常スキップ+空配列+全スキップ+マッピング省略+inputFiles空の5パターン"
  AC-2, "TC-AC2-01/TC-AC2-02/TC-AC2-03/TC-AC2-04", "不在エラー+存在通過+outputFile未定義フェーズ+forceTransitionの4パターン"
  AC-3, "TC-AC3-01/TC-AC3-02/TC-AC3-03", "プロンプト含有+定数定義+プレースホルダ未使用の3パターン"
  AC-4, "TC-AC4-01/TC-AC4-02/TC-AC4-03", "100バイト未満+ちょうど100バイト+0バイトの3境界値"
  AC-5, "TC-AC5-01/TC-AC5-02/TC-AC5-03", "読み込んでパターン+ファイルを読みパターン+通常テキスト保持の3パターン"
  AC-6, "TC-AC6-01/TC-AC6-02/TC-AC6-03", "外部カテゴリ+ファイル不在フォールバック+不正JSONフォールバックの3パターン"
  AC-7, TC-AC7-01, "6ファイル全数の行数確認"
  AC-8, TC-AC8-01, "vitest run全パス確認"

