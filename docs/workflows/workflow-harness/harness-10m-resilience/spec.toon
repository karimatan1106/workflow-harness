p1Spec:
  targetFunction: "checkInputFilesExist(phase,docsDir,workflowDir,skippedPhases?,fileToPhaseMap?)"
  newParams: "skippedPhases: string[] = [], fileToPhaseMap: Record<string,string> = {}"
  logic: "config.inputFilesループ内でconst basename = inputFile.split('/').pop() ?? ''を算出。const sourcePhase = fileToPhaseMap[basename]を逆引き。sourcePhaseが存在しskippedPhases.includes(sourcePhase)がtrueならcontinueでスキップ"
  callerChange: "dod.ts L35: checkInputFilesExist(phase,docsDir,workflowDir,state.skippedPhases,OUTPUT_FILE_TO_PHASE)"
  importChange: "dod.ts L8の後に import { OUTPUT_FILE_TO_PHASE } from '../phases/definitions.js' を追加。OUTPUT_FILE_TO_PHASEのexport修飾子を追加(definitions.ts L43: const→export const)"

p2p4Spec:
  insertAfter: "lifecycle.ts L91(const docsDir行)"
  importChange: "L1付近に import { existsSync, statSync } from 'node:fs' を追加"
  code: "const config = PHASE_REGISTRY[task.phase as keyof typeof PHASE_REGISTRY]; if (config?.outputFile) { const outPath = config.outputFile.replace('{docsDir}',docsDir).replace('{workflowDir}',task.workflowDir ?? ''); if (!existsSync(outPath)) return respondError('成果物ファイルが存在しません: '+outPath+'. フェーズ作業を完了してから harness_next を呼び出してください。'); if (statSync(outPath).size < 100) return respondError('成果物ファイルが空または不完全です ('+statSync(outPath).size+' bytes): '+outPath); }"
  lineEstimate: "8-10行追加"

p3Spec:
  fragmentName: PROCEDURE_ORDER_RULE
  location: "definitions-shared.ts L47の直後"
  content: "export const PROCEDURE_ORDER_RULE = '=== 作業順序(必須) ===\\n(1)入力ファイルをRead→(2)内容を分析→(3)成果物をWrite→(4)書いたファイルをReadして検証→(5)結果報告';"
  expansionLine: "definitions.ts L138の後に prompt = prompt.replace(/\\{PROCEDURE_ORDER\\}/g, PROCEDURE_ORDER_RULE);"
  importChange: "definitions.ts L10のimportにPROCEDURE_ORDER_RULEを追加"
  templateUpdate: "各defs-stage*.tsのテンプレート末尾に{PROCEDURE_ORDER}プレースホルダを追加する必要あり。ただしEXIT_CODE_RULEと同様にフラグメント展開で挿入されるため既にプレースホルダがあるテンプレートのみ対象"

p5Spec:
  regexPattern: "/^.*(?:読み込んで|ファイルを読み).*$/gm"
  insertAfter: "definitions.ts L132(既存## 入力ストリップの直後)"
  falsePositiveRisk: "低。テンプレート内で読み込んでを含む行は入力指示文脈のみ。OQ-2検証で対象はdefs-stage3 L24とdefs-stage4 L52の2行のみ。成果物品質ルールや手順説明に読み込んでは使用されていない"
  skillFileUpdate: "workflow-execution.md L48後に4行追加: サブエージェントテンプレート内のRead指示行はbuildSubagentPromptが自動除去する旨のルール"

p6Spec:
  functionName: loadTraitCategories
  signature: "function loadTraitCategories(): Record<string, string[]>"
  defaultConst: "DEFAULT_TRAIT_CATEGORIES(現TRAIT_CATEGORIESをリネーム)"
  logic: "try { const raw = readFileSync('.harness.json','utf8'); const parsed = JSON.parse(raw); if (parsed.traitCategories && typeof parsed.traitCategories === 'object') return parsed.traitCategories; } catch {} return DEFAULT_TRAIT_CATEGORIES;"
  importChange: "definitions.ts L1付近に import { readFileSync } from 'node:fs' を追加"
  callerChange: "L101のTRAIT_CATEGORIES参照をloadTraitCategories()呼び出しに変更"

decisions[8]{id,statement,rationale}:
  PL-1, "OUTPUT_FILE_TO_PHASEはdefinitions.tsからdod.tsへimportし引数としてcheckInputFilesExistに渡す", "OQ-1検証で循環依存なしを確認済み。直接importが安全であり引数方式より型安全性が高い。ただし変更範囲最小化のためREQ-D-1の引数方式を維持する"
  PL-2, "P2+P4先行チェックはlifecycle.ts L91-92間に単一ブロックとして挿入する", "存在チェックとサイズチェックを分離すると2箇所にearly-returnが分散する。単一ブロックで両方を検証する方が保守性が高い"
  PL-3, "P5のRead指示除去regexは/^.*(?:読み込んで|ファイルを読み).*$/gmとする", "OQ-2検証で対象行がdefs-stage3 L24とdefs-stage4 L52の2行のみであることを確認。Read\\s*toolパターンは現テンプレートに該当なく不要。読み込んでとファイルを読みの2パターンで十分"
  PL-4, "PROCEDURE_ORDER_RULEは全テンプレートに{PROCEDURE_ORDER}プレースホルダとして展開する", "EXIT_CODE_RULEと同じパターン。テンプレート側にプレースホルダがなければ展開されないため既存テンプレートへの影響はプレースホルダ追加分のみ"
  PL-5, "loadTraitCategoriesはreadFileSyncベースの同期関数とし呼び出し毎に.harness.jsonを読む", "buildSubagentPromptが同期関数であり非同期化は呼び出しチェーン全体に波及する。設定ファイルは小さく毎回読込のコストは無視可能"
  PL-6, "definitions.ts L43のOUTPUT_FILE_TO_PHASEにexport修飾子を追加する", "dod.tsからimportするために必要。既存のbuildToonFirstSection関数はファイル内関数であり外部参照はないためexport追加による副作用なし"
  PL-7, "P5のregex挿入位置はL132(既存## 入力ストリップ)の直後とする", "既存ストリップ処理で除去しきれなかった残存Read指示行を補完的に除去する。フラグメント展開前に配置することでフラグメント内のRead指示も対象とする"
  PL-8, "defs-stage3/stage4のテンプレートにも{PROCEDURE_ORDER}プレースホルダを追加する", "P3フラグメントがdesign_review/implementationのサブエージェントに手順確定化を提供するために必要。他のstageファイルにも順次追加するが本タスクでは全stageを対象とする"

testStrategy[4]{id,target,method,expectedResult}:
  PL-TS-1, P1, "skippedPhases=['state_machine']を含むTaskStateでrunDoDChecksを呼び出しstate-machine.mmdのinputFilesチェックがスキップされることを検証", "dodResult.passedがtrue(他のチェックが全パスの前提で)"
  PL-TS-2, P2+P4, "outputFileが存在しない/100バイト未満の状態でhandleHarnessNextを呼び出しrespondErrorが返却されることを検証", "error文字列に成果物ファイルが存在しませんまたは空または不完全ですを含む"
  PL-TS-3, P5, "読み込んでを含むテンプレート文字列をbuildSubagentPromptに入力し出力に読み込んでが含まれないことを検証", "prompt.includes('読み込んで')がfalse"
  PL-TS-4, P6, ".harness.json存在時と不在時でloadTraitCategoriesの返り値が異なることを検証", "存在時は外部定義値、不在時はDEFAULT_TRAIT_CATEGORIES"

