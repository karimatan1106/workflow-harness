flowchart TD
    A("開始: テスト出力受信") --> B("出力文字列を入力")
    B --> C{FR-1: テストフレームワーク<br/>パターンマッチング}

    C -->|Jest形式<br/>Tests: 検出| D("Testsパターン<br/>で処理")
    C -->|Jest形式<br/>Test Suites: 検出| E("Test Suitesパターン<br/>で処理")
    C -->|vitest複合形式<br/>N failed &#124; M passed| F("新規複合形式パターン<br/>で処理")
    C -->|vitest単純形式<br/>M passed のみ| G("既存vitestパターン<br/>で処理")
    C -->|Mocha形式<br/>検出| H("Mochaパターン<br/>で処理")
    C -->|パターン未マッチ| I("カウント抽出失敗<br/>null返却")

    D --> J("passedカウント抽出")
    E --> J
    F --> K("複合形式から<br/>正確なpassedカウント抽出<br/>失敗件数は無視")
    G --> J
    H --> J
    K --> L("testCount設定<br/>複合形式テスト完了")
    J --> M("testCount設定<br/>単純形式テスト完了")
    L --> N{FR-2: exitCode<br/>矛盾チェック}
    M --> N
    I --> N

    N -->|exitCode = 0| O("出力を行単位<br/>に分割")
    N -->|exitCode ≠ 0| P("既存判定ロジック<br/>を実行")

    O --> Q("各行をコンテキスト<br/>分類")
    Q --> R{行カテゴリ<br/>判定}

    R -->|集計行<br/>Tests:/Test Files:| S("カテゴリA<br/>集計行")
    R -->|テスト名行<br/>✓/✗記号またはインデント| T("カテゴリB<br/>テスト名行")
    R -->|スタックトレース行<br/>at やファイルパス| U("カテゴリC<br/>スタックトレース行")
    R -->|その他| V("カテゴリD<br/>その他行")

    S --> W{キーワード検出<br/>対象か?}
    T --> X("除外条件適用<br/>キーワード検出なし")
    U --> Y("除外条件適用<br/>キーワード検出なし")
    V --> W

    W -->|BLOCKING_FAILURE_KEYWORDS<br/>検出あり| Z("ブロック判定<br/>valid: false")
    W -->|キーワード<br/>検出なし| AA("通過判定<br/>valid: true")

    X --> AA
    Y --> AA
    P --> AB{キーワード<br/>検出あり?}
    AB -->|あり| AC("ブロック判定<br/>valid: false<br/>非ゼロexitCode")
    AB -->|なし| AA

    Z --> AD("FR-4: 成果物<br/>バリデーション<br/>品質チェック")
    AA --> AD
    AC --> AD

    AD --> AE("禁止語スキャン<br/>実施")
    AE --> AF{禁止語<br/>検出?}
    AF -->|英語/日本語<br/>禁止語あり| AG("バリデーション失敗<br/>エラー返却")
    AF -->|禁止語<br/>なし| AH("密度計算開始<br/>コードフェンス除外")

    AH --> AI("各セクションの<br/>実質行計算")
    AI --> AJ("セクション密度<br/>= 実質行数 / 総行数")
    AJ --> AK{密度 >= 0.30<br/>かつ実質行 >= 5行?}
    AK -->|いいえ| AL("密度不足<br/>バリデーション失敗")
    AK -->|はい| AM("重複行チェック<br/>開始")

    AM --> AN("構造要素<br/>を除外")
    AN --> AO("同一行の<br/>出現回数確認")
    AO --> AP{同一行 >= 3回<br/>検出?}
    AP -->|はい| AQ("重複行エラー<br/>バリデーション失敗")
    AP -->|いいえ| AR("必須セクション<br/>確認")

    AR --> AS{必須セクション<br/>存在?}
    AS -->|欠落あり| AT("必須セクション欠落<br/>バリデーション失敗")
    AS -->|全て存在| AU("FR-5: リトライ<br/>テンプレート<br/>適用")

    AL --> AV("バリデーション<br/>エラーメッセージ<br/>生成")
    AQ --> AV
    AT --> AV
    AG --> AV

    AV --> AW("subagent<br/>リトライ実行")
    AW --> AX("リトライプロンプト<br/>生成")
    AX --> AY("エラー引用を<br/>コードブロック<br/>で記載")
    AY --> AZ("改善要求セクション<br/>作成")
    AZ --> BA("禁止語直接転記<br/>チェック")
    BA --> BB{禁止語が<br/>引用から転記<br/>されていないか?}
    BB -->|転記あり| BC("リトライ失敗<br/>サイクル再開")
    BB -->|転記なし| BD("リトライ実行<br/>再投入")

    AU --> AU2("成果物バリデーション<br/>成功")
    AU2 --> CE("タスク完了")
    BD --> BD2("新規バリデーション<br/>実施")
    BD2 --> AD

    CE --> CF("終了: 全フェーズ<br/>クリア")
