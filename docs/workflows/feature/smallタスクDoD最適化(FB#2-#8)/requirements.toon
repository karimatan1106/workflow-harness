  CS-1, "workflow-harness/mcp-server/src/phases/registry.ts", "modify", "SIZE_SKIP_MAP.smallにresearch/planning追加。getPhaseConfigにsize引数追加。SIZE_MINLINES_FACTOR定数追加"
  CS-2, "workflow-harness/mcp-server/src/gates/dod-l4-delta.ts", "modify", "DELTA_ENTRY_MIN_COUNTをsize依存Mapに変更。checkDeltaEntryFormatにsize引数追加"
  CS-3, "workflow-harness/mcp-server/src/gates/dod-l1-l2.ts", "modify", "checkTDDRedEvidence冒頭にdodExemptionsチェック追加(3行)"
  CS-4, "workflow-harness/mcp-server/src/tools/handler-shared.ts", "modify", "PHASE_APPROVAL_GATESをshouldRequireApproval関数に置換"
  CS-5, "workflow-harness/mcp-server/src/tools/handlers/lifecycle.ts", "modify", "approval判定でstate.sizeをshouldRequireApprovalに渡す"
  CS-6, "workflow-harness/mcp-server/src/phases/definitions-shared.ts", "modify", "SUMMARY_SECTION_RULEに禁止記法リスト追加"

