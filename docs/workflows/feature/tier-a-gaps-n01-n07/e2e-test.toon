task: tier-a-gaps-n01-n07
phase: e2e_test
intent: Tier A 7項目のE2Eテスト実行と全テストスイート通過確認

e2eScenario1:
  name: reflector.ts + retry.ts 統合フロー
  flow: stashFailure → promoteStashedFailure → buildRetryPrompt
  verification: reflector-failure-loop.test.tsで2回以上の同一エラーパターン蓄積→preventionRule生成を確認
  testFile: src/__tests__/reflector-failure-loop.test.ts
  result: pass (9 tests)

e2eScenario2:
  name: ADR store → retry prompt 統合フロー
  flow: ADR作成 → getActiveADRs → buildRetryPromptでADRリンク表示
  verification: retry-adr.test.tsでADR存在時のpromptにADR-001が含まれること、最大3件制限、エラー時の安全な動作を確認
  testFile: src/__tests__/retry-adr.test.ts
  result: pass (5 tests)

e2eScenario3:
  name: 全テストスイート実行
  command: npx vitest --run
  workingDir: workflow-harness/mcp-server
  result: 56 test files passed, 509 tests passed, 0 failures

