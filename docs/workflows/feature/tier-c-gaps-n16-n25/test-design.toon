task: tier-c-gaps-n16-n25
phase: test_design
intent: AC-1~AC-7に対応するテストケース22件を5テストファイルに構成しRTM追跡マトリクスで全ACカバレッジを保証する

testFiles[5]{seq,fileName,gapId,acId,testCount,sourceFile}:
  1, plankton.test.ts, N-16, AC-1, 5, retry.ts
  2, skill-rules.test.ts, N-17, AC-2, 5, "dod-helpers.ts/handler-shared.ts/registry.ts"
  3, antipattern.test.ts, N-21, AC-5, 4, "archgate.ts/linter-runner.ts"
  4, e2e-mcp-chain.test.ts, N-20, AC-4, 3, "handler.ts/manager.ts"
  5, safety.test.ts, N-25, AC-6, 5, "manager-write.ts/lifecycle.ts"

testCases[22]{id,file,description,inputSetup,expectedResult,acTrace}:
  TC-AC1-01, plankton.test.ts, "L4エラー(density/formatting)がtrivialに分類される", "DoDCheckResult[]: [{level:'L4',check:'content_validation',passed:false,fix:'禁止語を削除'}]とerrorClass:'SyntaxError'を渡す", "classifyComplexity返却値が'trivial'", AC-1
  TC-AC1-02, plankton.test.ts, "L3エラー(missing section)がmoderateに分類される", "DoDCheckResult[]: [{level:'L3',check:'artifact_quality',passed:false}]とerrorClass:'LogicError'を渡す", "classifyComplexity返却値が'moderate'", AC-1
  TC-AC1-03, plankton.test.ts, "L1エラー(file missing)がcriticalに分類される", "DoDCheckResult[]: [{level:'L1',check:'output_file_exists',passed:false}]とerrorClass:'FileNotFound'を渡す", "classifyComplexity返却値が'critical'", AC-1
  TC-AC1-04, plankton.test.ts, "buildRetryPromptの出力に複雑度タグが含まれる", "RetryContext(retryCount:1)とDoDCheckResult[](L4エラー1件)を渡してbuildRetryPrompt呼び出し", "返却promptに'[TRIVIAL]'文字列が含まれる", AC-1
  TC-AC1-05, plankton.test.ts, "複数エラーの場合最も重い分類が使用される", "DoDCheckResult[]: L4(trivial相当)とL1(critical相当)の混合配列を渡す", "classifyComplexity返却値が'critical'(最重分類が優先)", AC-1
  TC-AC2-01, skill-rules.test.ts, "FORBIDDEN_PATTERNSが12語全て含む", "dod-helpers.tsからFORBIDDEN_PATTERNSをimport", "配列長が12かつ英語4語(半角大文字略語)+日本語8語(漢字/カタカナ混在)を全て含む", AC-2
  TC-AC2-02, skill-rules.test.ts, "TOON必須フィールド(decisions/artifacts/next)がレジストリに含まれる", "registry.tsからPHASE_REGISTRYをimportしtest_designエントリのrequiredSectionsを参照", "requiredSectionsが['decisions','artifacts','next']を含む", AC-2
  TC-AC2-03, skill-rules.test.ts, "PHASE_APPROVAL_GATESが5種含む", "handler-shared.tsからPHASE_APPROVAL_GATESをimport", "Object.keys長が5かつrequirements/design_review/test_design/code_review/acceptance_verificationをキーに含む", AC-2
  TC-AC2-04, skill-rules.test.ts, "PHASE_REGISTRYの各エントリがbashCategoriesフィールドを持つ", "registry.tsからPHASE_REGISTRYをimportし全エントリを走査", "全エントリのbashCategoriesがstring[]型で長さ1以上", AC-2
  TC-AC2-05, skill-rules.test.ts, "PHASE_REGISTRYの各エントリがminLinesフィールドを持つ", "registry.tsからPHASE_REGISTRYをimportし全エントリを走査", "全エントリのminLinesが数値で0超過", AC-2
  TC-AC5-01, antipattern.test.ts, "runCommentRatioが40%以下でpassed:true", "コメント行20%のTypeScriptコンテンツ(コード8行+コメント2行)を生成しcountCommentLines呼び出し", "ratio<=0.4かつ外側のarchgate判定がpassed:true", AC-5
  TC-AC5-02, antipattern.test.ts, "runCommentRatioが40%超過でpassed:false", "コメント行60%のコンテンツ(コード4行+コメント6行)を生成しcountCommentLines呼び出し", "ratio>0.4かつ外側のarchgate判定がpassed:false(violation報告)", AC-5
  TC-AC5-03, antipattern.test.ts, "comment_ratio checkTypeがarchgate runArchGateChecksで実行される", "archgate-rules.jsonにcomment_ratioルール(threshold:40)を登録しrunArchGateChecksにコメント率50%のFileInfo配列を渡す", "ArchGateResult.passed===falseかつchecks配列にcomment_ratio ruleIdのエントリが存在", AC-5
  TC-AC5-04, antipattern.test.ts, "空ファイルでpassed:true(ゼロ除算なし)", "空文字列をcountCommentLinesに渡す", "ratio===0かつエラーなし(totalLines===0でゼロ除算が発生しない)", AC-5
  TC-AC4-01, e2e-mcp-chain.test.ts, "lifecycle chain: start->set_scope->add_ac->next", "vi.mock('fs')でインメモリfsStore使用。handleToolCallにharness_start(taskName+userIntent)を渡し返却taskId/sessionTokenを取得。続けてharness_set_scope/harness_add_ac/harness_next(forceTransition:true)を呼び出す", "全4呼び出しが成功し各返却値のtaskIdが一貫。harness_next後のphaseがscope_definitionから遷移済み", AC-4
  TC-AC4-02, e2e-mcp-chain.test.ts, "quality chain: record_test->record_test_result->record_proof", "TC-AC4-01で取得したtaskId/sessionTokenを使用。harness_record_test(testId+description)→harness_record_test_result(exitCode:0)→harness_record_proof(result:true)を順次呼び出す", "全3呼び出しが成功しstate.proofLog配列にエントリが追加される", AC-4
  TC-AC4-03, e2e-mcp-chain.test.ts, "verification chain: approve->next->complete", "承認ゲート対象フェーズまで進めた後harness_approve→harness_next→承認後遷移を確認", "harness_approve成功後のharness_nextがphase遷移を実行", AC-4
  TC-AC6-01, safety.test.ts, "taskNameにパストラバーサル(../)でsanitize後にトラバーサルなし", "sanitizeTaskName('../../etc/passwd')を呼び出す", "返却値に'..'や'/'が含まれない。返却値が'etcpasswd'または'passwd'", AC-6
  TC-AC6-02, safety.test.ts, "taskNameに特殊文字(:*?<>|)でsanitize後に除去", "sanitizeTaskName('task:name*with?special<>|chars')を呼び出す", "返却値が'tasknamewithspecialchars'(英数字とハイフン/アンダースコアのみ残る)", AC-6
  TC-AC6-03, safety.test.ts, "userIntentが10000文字超過でtruncateされる", "handleHarnessStartに10001文字のuserIntentを渡す", "respondErrorが呼ばれvalidation errorメッセージにmaxLength超過が示される", AC-6
  TC-AC6-04, safety.test.ts, "XSSペイロード(<script>)がエスケープまたは除去される", "sanitizeTaskName('<script>alert(1)</script>')を呼び出す", "返却値に'<'や'>'が含まれない。返却値が'scriptalert1script'", AC-6
  TC-AC6-05, safety.test.ts, "SQLインジェクション('; DROP TABLE)が安全に処理される", "sanitizeTaskName(\"'; DROP TABLE tasks;--\")を呼び出す", "返却値に引用符やセミコロンが含まれない。返却値が'DROPTABLEtasks--'または類似の安全な文字列", AC-6

