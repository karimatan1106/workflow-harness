typeDesign[6]{id,signature,location,description}:
  TD-1, "type ComplexityLevel = 'trivial' | 'moderate' | 'critical'", retry.ts, "DoDCheckResultのcheck/passed/levelフィールドから修正難易度を3段階に分類する型。trivial=禁止語/プレースホルダー(fix存在)、moderate=密度不足/行数不足(artifact_quality失敗)、critical=ファイル未存在/L1失敗2件以上"
  TD-2, "classifyComplexity(errorClass: RetryPromptResult['errorClass'], checks: DoDCheckResult[]): ComplexityLevel", retry.ts, "errorClassの4分類(FileNotFound/SyntaxError/LogicError/Unknown)とDoDCheckResult配列から複雑度を判定する純粋関数。FileNotFound→critical、SyntaxError+fix存在→trivial、それ以外→checks分析で判定"
  TD-3, "sanitizeTaskName(name: string): string", manager-write.ts, "path.basename適用→/[^a-zA-Z0-9\\-_]/g除去→NULバイト/制御文字除去→最大100文字切り詰め。空文字列の場合はエラーをthrow"
  TD-4, "countCommentLines(content: string): {commentLines: number, totalLines: number, ratio: number}", linter-runner.ts, "単行コメント(^\\s*//)とブロックコメント(/* */間の行)を計数しコメント行比率を返す。空行はtotalLinesに含むがcommentLinesには含まない"
  TD-5, "runArchGateQuickCheck(filePath: string, content: string): {passed: boolean, violations: string[]}", linter-runner.ts, "archgate-rules.jsonからpattern_absent/pattern_requiredルールのみフィルタしglob一致ファイルに対してregex評価。AbortController+setTimeout(100)でtimeout。タイムアウト時はpassed:trueを返す"
  TD-6, "ArchCheckType = 'line_count' | 'pattern_absent' | 'pattern_required' | 'duplicate_code' | 'ast_grep_pattern' | 'comment_ratio'", archgate.ts, "既存5種にcomment_ratioを追加したunion型。runArchGateChecks内のswitch文にcomment_ratioブランチを追加"

classifyComplexityLogic:
  trivialConditions: "errorClass='SyntaxError' AND 全failed checksにfixフィールドが存在 AND failed checks数が2以下"
  moderateConditions: "errorClass='LogicError' OR (errorClass='SyntaxError' AND fix欠落あり) OR failed checks数が3-4"
  criticalConditions: "errorClass='FileNotFound' OR L1レベルの失敗が2件以上 OR failed checks数が5以上"
  fallback: "errorClass='Unknown'の場合はfailed checks数で判定: 0-2=trivial, 3-4=moderate, 5+=critical"

sanitizeTaskNameLogic:
  step1: "NULバイト(\\x00)と制御文字(\\x01-\\x1f)を空文字に置換"
  step2: "path.basename()を適用しディレクトリ部分を除去(../等のトラバーサル防止)"
  step3: "正規表現/[^a-zA-Z0-9\\-_]/gで許可文字以外を除去"
  step4: "先頭・末尾のハイフン/アンダースコアをtrim"
  step5: "100文字超過時はslice(0,100)で切り詰め"
  step6: "結果が空文字列の場合throw new Error('Invalid taskName: empty after sanitization')"

commentRatioLogic:
  singleLinePattern: "^\\s*//で始まる行をコメント行として計数"
  blockCommentTracking: "/*を検出したらブロック内フラグをON、*/を検出したらOFF。フラグON中の全行をコメント行として計数"
  ratioCalculation: "ratio = commentLines / totalLines (totalLines=0の場合ratio=0)"
  thresholdDefault: "archgate-rules.jsonのthresholdフィールドで指定。未指定時デフォルト40%"
  violationCondition: "ratio > threshold/100の場合violation報告"

archgateQuickCheckLogic:
  ruleFilter: "loadRuleStore()からcheckType='pattern_absent'またはcheckType='pattern_required'のルールのみ抽出"
  globMatch: "archgate.tsのmatchGlob関数(export化済み)でfilePath引数とルールのglobフィールドを照合"
  patternEval: "new RegExp(rule.pattern)でcontent引数を評価。pattern_absent→matchでviolation、pattern_required→non-matchでviolation"
  timeout: "AbortControllerのsignal+setTimeout(100ms)でタイムアウト制御。タイムアウト時は{passed:true, violations:[]}を返す"
  caching: "loadRuleStore()結果をモジュールレベル変数にキャッシュし同一プロセス内で再読み込みを回避"

postToolLintIntegration:
  insertionPoint: "post-tool-lint.shのexit 0直前(line86付近)"
  nodeCommand: "timeout 3 node -e \"require('./workflow-harness/mcp-server/dist/tools/linter-runner.js').runArchGateQuickCheck('$FILE_PATH', require('fs').readFileSync('$FILE_PATH','utf-8'))\""
  errorHandling: "node実行失敗(exit code非0)時はecho警告メッセージのみ出力しexit 0で続行"
  windowsNote: "MSYS_NT環境ではnodeパスがPATH依存のためcommand -v node確認を先行させる"

e2eTestStrategy:
  mockApproach: "vi.mock('fs')でインメモリfsStore使用。vi.mock('../utils/hmac.js')でHMAC検証をバイパス"
  chain1Lifecycle: "harness_start(taskName+userIntent)→harness_set_scope→harness_add_ac→harness_next(forceTransition:true)の順にhandleToolCallを呼び出しtaskId/sessionTokenの一貫性を検証"
  chain2Quality: "harness_record_test→harness_record_test_result→harness_record_proofの連鎖で状態遷移を検証。各ツールの返却値からstate変化を確認"
  chain3Verification: "registerArchRule→runArchGateChecks→DoD失敗→buildRetryPromptの連鎖を検証。archgateルール登録後のDoD検証でviolation検出とリトライプロンプト生成を確認"

