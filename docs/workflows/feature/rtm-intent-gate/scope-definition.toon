  src/gates/dod-l4-ia.ts, "checkAcDesignMapping/checkAcTcMapping/checkAcAchievementTable/checkTCCoverage — IA-3〜5クロスフェーズAC追跡"
  src/gates/dod.ts, "runDoDChecks オーケストレーター — 全L1〜L4チェックの実行順序定義"
