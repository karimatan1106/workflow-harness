  src/phases/defs-stage1.ts, "requirementsフェーズ subagentTemplate — OPEN_QUESTIONS確認ループのオーケストレーター指示"
  src/phases/registry.ts, "PHASE_REGISTRY — requirements/design_review/test_design/code_review の requiredSections 定義"

currentImplementation[6]{check,location,gap}:
  checkOpenQuestions, "dod-l4-requirements.ts:110-130", "存在確認のみ。空配列と有効項目の区別なし。DoDゲートとしてopenQuestionsが非空の場合にブロックする仕組みが欠落"
  checkRTMCompleteness, "dod-l3.ts:41-58", "code_review/acceptance_verification/completedの3フェーズのみ検査。requirements→design_review→test_designのクロスフェーズAC追跡が途切れる"
  checkAcDesignMapping, "dod-l4-ia.ts:12-38", "design_reviewでacDesignMapping必須チェック実装済み。state.acceptanceCriteriaとの突合検証あり"
  checkAcTcMapping, "dod-l4-ia.ts:42-61", "test_designでacTcMapping必須チェック実装済み。AC件数との突合なし（checkTCCoverageで補完）"
  checkAcAchievementTable, "dod-l4-ia.ts:90-128", "code_reviewでacAchievementStatus必須チェック実装済み。not_met判定あり"
  openQuestionsApprovalBlock, "handlers/approval.ts:35-52", "requirementsフェーズ承認時にopenQuestions非空をブロックする実装あり。DoDゲート（harness_next）では未検査"

gapAnalysis[5]{id,description,affectedFiles}:
  GAP-RTM-1, "requirementsフェーズDoD: openQuestionsが空配列でない場合にharness_nextをブロックするL4ゲートが未実装。checkOpenQuestionsは存在確認のみで内容を検査しない", "gates/dod-l4-requirements.ts"
  GAP-RTM-2, "design_reviewフェーズDoD: acDesignMappingのAC-N件数完全一致チェックが実装済みだが、requirementsフェーズでRTM F-NNNエントリをharness_add_rtmで追加する要件がsubagentTemplateに明示されていない", "phases/defs-stage1.ts"
  GAP-RTM-3, "test_designフェーズDoD: acTcMappingとtcCoverageが独立チェックで実装済み。しかしRTMエントリのstatusをpending→implementedに更新するゲートがtest_design/code_reviewに不在", "gates/dod-l4-ia.ts, gates/dod-l3.ts"
  GAP-RTM-4, "harness_nextのIA-1ループ: checkOpenQuestionsがDoD失敗を返してもretryPromptにOPEN_QUESTIONS解消の具体的指示が含まれない。ユーザー確認の促しがrequirementsテンプレートのコメントのみで強制されない", "tools/handlers/lifecycle.ts, tools/retry.ts"
  GAP-RTM-5, "RTMチェーンの連続性: requirements→design_review→test_design→code_reviewの各フェーズでAC-N IDが一貫して参照されることの機械的検証が欠落。acDesignMappingとacTcMappingで個別チェックはあるが、F-NNNとAC-Nの連鎖検証がない", "gates/dod.ts, gates/dod-l3.ts"

